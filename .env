# configuration base de données
DATABASE_URL="mysql://root:@localhost:3306/commune_connecte_db"

# configuration du serveur
PORT=2025
#HOST=localhost
HOST=localhost
SOCKET_PORT=2026

# configuration de l'environnement UTILISER DANS SWAGGER
API_URL=http://localhost:2025/api
#
NODE_ENV=development

# configuration de JWT
SALT_ROUNDS=12
JWT_SECRET=123456789
JWT_EXPIRES_IN=7d

# configuration de CORS
CLIENT_URL=http://localhost:3000

# configuration de l'email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=commune@gmail.com
MAIL_PASS=123456789
MAIL_FROM="CommuneConnecte <commune@gmail.com>"

# configuration de l'upload de fichiers
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./storage
ALLOWED_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,image/jpeg,image/png,image/gif


# configuration de la limite de requêtes
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5
